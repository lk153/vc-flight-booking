# Flight data providers (set one or both — mock data is used if none are set)

# Option 1: Amadeus API (free tier - https://developers.amadeus.com/register)
AMADEUS_CLIENT_ID=your_client_id
AMADEUS_CLIENT_SECRET=your_client_secret

# Option 2: SerpApi Google Flights (free trial - https://serpapi.com/users/sign_up)
SERPAPI_KEY=your_serpapi_key

# Database
DATABASE_URL=postgresql://user:pass@host:5432/vc_flights

# Redis Cache
REDIS_URL=redis://localhost:6379

# Email (Resend)
RESEND_API_KEY=your_resend_key

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Mobile Push via ntfy.sh (free, no account — https://ntfy.sh)
NTFY_TOPIC=your_ntfy_topic

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your_cron_secret
